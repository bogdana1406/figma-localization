# секреты
.env

# данные проектов: экспорты, переводы, память, промежуточные файлы — по умолчанию не в git
projects/*/exports/
projects/*/translations/

# НО промпты — это часть системы (настройка перевода), их храним в git.
# Правило-исключение: не игнорировать папки prompts внутри проектов.
!projects/*/prompts/
!projects/*/prompts/**

# служебное
__pycache__/
*.pyc
.DS_Store
.venv/
venv/

# сборка плагина, если появится
plugin/node_modules/

# ── ЗАМЕТКА НА БУДУЩЕЕ ─────────────────────────────────────────────────────
# В конце сборки системы решим, что из projects/ ещё стоит коммитить:
# финальные вычитанные переводы (hyperocket-<lang>.csv) и память (memory.csv)
# полезно хранить в git, чтобы не путаться, где выверенное. Тогда добавим
# сюда точечные правила-исключения вроде:
#   !projects/*/translations/*/hyperocket-*.csv
#   !projects/*/translations/*/memory.csv
# Промежуточные layout.csv / to_translate.csv останутся игнорируемыми.
