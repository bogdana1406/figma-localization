
# ── Секреты ───────────────────────────────────────────────────────────────
.env
 
# ── Служебное ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
.venv/
venv/
plugin/node_modules/
 
# ── Данные проектов ───────────────────────────────────────────────────────
# По умолчанию НЕ игнорируем данные проектов — храним в git то, что ценно:
#   • экспорты (снимки макета, нужны для диффа)
#   • финальные переводы hyperocket-<lang>.csv
#   • память memory.csv (архив всех вычитанных переводов — самое ценное)
#   • файлы для дизайнера (-design-*.csv) и отчёты импорта (-imported-*.csv)
#   • промпты
#
# Игнорируем ТОЛЬКО промежуточные рабочие файлы одного прогона — они
# пересоздаются из других и в истории только шум:
projects/*/translations/*/layout.csv
projects/*/translations/*/to_translate.csv
 
# Отчёты о проблемах перевода (тоже временные, генерируются translate.py)
projects/*/translations/*/*-problems.csv
 
# Бэкапы финала, которые finalize делает перед перезаписью (в истории git
# и так есть предыдущие версии, дублировать бэкапами не нужно)
projects/*/translations/*/*.backup-*.csv